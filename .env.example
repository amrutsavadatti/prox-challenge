ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=

# Voice (optional). Default provider is OpenAI for both STT and TTS.
# OPENAI_API_KEY=sk-...
# VOICE_STT_PROVIDER=openai          # or deepgram
# VOICE_TTS_PROVIDER=openai          # or elevenlabs
# OPENAI_TTS_MODEL=gpt-4o-mini-tts   # expressive tone via `instructions`
# OPENAI_TTS_VOICE=ash
# DEEPGRAM_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_turbo_v2_5
